generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MUSICIAN
}

enum AssignmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum EventType {
  WEDDING
  CEREMONY
  RECEPTION
  RESTAURANT
  OTHER
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum PaymentDirection {
  RECEIVABLE
  PAYABLE
}

enum PaymentStatus {
  PENDING
  RECEIVED
  REFUNDED
  PAID
  CANCELLED
}

enum PaymentType {
  CONTRACT_RECEIVABLE
  MUSICIAN_PAYABLE
  RESTAURANT_RECEIVABLE
  OTHER
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum RestaurantContractStatus {
  ACTIVE
  ENDED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  login        String?  @unique
  name         String
  role         Role
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  musicianProfile MusicianProfile?
  taskReminders   TaskReminder[]
}

model MusicianProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  phone         String?
  instrument    String?
  bio           String?
  baseCacheCents Int     @default(0)
  active        Boolean  @default(true)
  lastSeen      DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments Assignment[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  message   String?
  createdAt DateTime @default(now())
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts RestaurantContract[]
}

model RestaurantContract {
  id                 String                  @id @default(cuid())
  restaurantId       String
  startDate          DateTime
  endDate            DateTime
  time               String
  paymentFrequency   PaymentFrequency
  receivableTotalCents Int                   @default(0)
  totalCents         Int                     @default(0)
  status             RestaurantContractStatus @default(ACTIVE)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  events      Event[]
}

model Event {
  id           String    @id @default(cuid())
  title        String
  date         DateTime
  eventType    EventType @default(WEDDING)
  locationName String?
  address      String?
  city         String?
  state        String?
  mapUrl       String?
  notes        String?
  timeline     String?
  repertoire   String?

  clientId  String?
  client    Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contract  Contract?
  restaurantContractId String?
  restaurantContract   RestaurantContract? @relation(fields: [restaurantContractId], references: [id], onDelete: SetNull)
  payments  Payment[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  assignments Assignment[]
}

model Contract {
  id          String         @id @default(cuid())
  eventId     String         @unique
  totalAmount Int            @default(0)
  terms       String         @default("")
  status      ContractStatus @default(DRAFT)
  sentAt      DateTime?
  signedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model MusicianProfileLink {
  id        String   @id @default(cuid())
  musicianId String
  label     String
  url       String
  createdAt DateTime @default(now())
}

model Assignment {
  id         String           @id @default(cuid())
  eventId    String
  musicianId String
  roleName   String?
  status     AssignmentStatus @default(PENDING)
  costCents  Int?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  event    Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  musician MusicianProfile @relation(fields: [musicianId], references: [id], onDelete: Cascade)

  @@unique([eventId, musicianId], name: "eventId_musicianId")
}

model NotificationAck {
  id           String   @id @default(cuid())
  userId       String
  assignmentId String
  readAt       DateTime @default(now())
  createdAt    DateTime @default(now())
  @@unique([userId, assignmentId], name: "userId_assignmentId")
}

model TaskReminder {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  startAt     DateTime
  durationMin Int      @default(30)
  color       String   @default("blue")
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, startAt], name: "userId_startAt")
  @@index([userId, startAt], name: "userId_startAt_idx")
}

model Payment {
  id        String          @id @default(cuid())
  eventId   String
  type      PaymentType     @default(OTHER)
  direction PaymentDirection
  contractId String?        @unique
  assignmentId String?      @unique
  restaurantContractId String?
  amount    Int
  status    PaymentStatus   @default(PENDING)
  dueDate   DateTime?
  paidAt    DateTime?
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

